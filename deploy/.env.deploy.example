# deploy/.env.deploy — copy to deploy/.env.deploy and fill in.
# Sourced by deploy/deploy.sh and deploy/update.sh.
# This file is gitignored.

# SSH target — the VM you're deploying to.
DEPLOY_HOST=ubuntu@simplysafelegacy.com

# Optional: SSH port (default 22) and identity file.
# DEPLOY_SSH_PORT=22
# DEPLOY_IDENTITY_FILE=~/.ssh/id_ed25519

# Where on the VM the app should live. Created by deploy.sh if missing.
DEPLOY_PATH=/opt/simplysafelegacy

# The public domain Caddy will serve. Default is the production host.
# Pass --dev on the command line to override to CADDY_DOMAIN_DEV.
# DNS A record must point at the VM *before* the first deploy or
# Let's Encrypt can't issue the cert.
CADDY_DOMAIN=app.simplysafelegacy.com
CADDY_DOMAIN_DEV=dev.simplysafelegacy.com
