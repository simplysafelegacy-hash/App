# Simply Safe Legacy — example environment file. Copy to `.env` before
# running `docker compose up`. Every value has a safe default in
# docker-compose.yml, so you may start with an empty .env.

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=simplysafelegacy
POSTGRES_PASSWORD=simplysafelegacy_dev_password
POSTGRES_DB=simplysafelegacy
POSTGRES_PORT=5432

# ── Backend ────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8080
# MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
JWT_EXPIRY=168h
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173

# ── Public-facing app URL ─────────────────────────────────────────────────
# Used by Stripe Checkout success/cancel redirects. Set to your domain in
# production, e.g. https://dev.simplysafelegacy.com
PUBLIC_APP_URL=http://localhost:8000

# ── Google OAuth (required — alongside email/password sign-in) ─────────────
# Create a Web Application OAuth 2.0 Client ID in Google Cloud Console.
# See README.md for the exact authorized origins / redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (placeholder values — replace before going live) ───────────────
# Test keys (sk_test_ / pk_test_) are fine for dev. The webhook secret is
# obtained from `stripe listen` in dev, or from the Stripe dashboard's
# webhook endpoint configuration in production.
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Create three recurring prices in the Stripe dashboard; paste their ids:
STRIPE_PRICE_INDIVIDUAL=price_REPLACE_ME_INDIVIDUAL
STRIPE_PRICE_FAMILY=price_REPLACE_ME_FAMILY
STRIPE_PRICE_SAFEKEEPING=price_REPLACE_ME_SAFEKEEPING
STRIPE_TRIAL_DAYS=14

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_PORT=8000
# Same value as GOOGLE_CLIENT_ID above — embedded into the SPA at build time.
VITE_GOOGLE_CLIENT_ID=

# ── Frontend dev (vite dev server — only used outside docker) ──────────────
# VITE_DEMO_MODE=true  # keep in-memory mock data; set false to hit the API
# VITE_API_URL=/api     # defaults to /api which vite proxies to :8080
