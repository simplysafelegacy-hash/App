# Sealed — example environment file. Copy to `.env` before running
# `docker compose up`. Every value has a safe default in docker-compose.yml,
# so you may start with an empty .env.

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=sealed
POSTGRES_PASSWORD=sealed_dev_password
POSTGRES_DB=sealed
POSTGRES_PORT=5432

# ── Object storage (MinIO locally, S3 in production) ───────────────────────
S3_BUCKET=sealed-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=sealed_dev
S3_SECRET_KEY=sealed_dev_password
S3_ENDPOINT=http://minio:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Backend ────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8080
# MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
JWT_EXPIRY=168h
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173

# ── Google OAuth (required — Google is the only sign-in method) ────────────
# Create a Web Application OAuth 2.0 Client ID in Google Cloud Console.
# See README.md for the exact authorized origins / redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_PORT=8000
# Same value as GOOGLE_CLIENT_ID above — embedded into the SPA at build time.
VITE_GOOGLE_CLIENT_ID=

# ── Frontend dev (vite dev server — only used outside docker) ──────────────
# VITE_DEMO_MODE=true  # keep in-memory mock data; set false to hit the API
# VITE_API_URL=/api     # defaults to /api which vite proxies to :8080
